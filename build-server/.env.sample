REDIS_URL=redis://localhost:6379

# AWS — local dev only. In ECS use IAM Task Role (no keys needed).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

S3_BUCKET=your-sideops-bucket

# Optional: custom S3 endpoint (for MinIO, R2, etc.)
# For MinIO local: http://localhost:9000
# For Cloudflare R2: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
MinIO=http://localhost:9000

# Required when using path-style endpoints like MinIO
S3_FORCE_PATH_STYLE=true

# How many builds to run in parallel (local worker mode)
WORKER_CONCURRENCY=2
